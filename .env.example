# ─── Auth Service ────────────────────────────────────────────
AUTH_PORT=3001
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me_auth

JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── Academic Service ─────────────────────────────────────────
ACADEMIC_PORT=3002
ACADEMIC_DB_HOST=academic-db
ACADEMIC_DB_PORT=5432
ACADEMIC_DB_NAME=academic_db
ACADEMIC_DB_USER=academic_user
ACADEMIC_DB_PASSWORD=change_me_academic

AUTH_SERVICE_URL=http://auth-service:3001

# ─── Assignment Service ───────────────────────────────────────
ASSIGNMENT_PORT=3003
ASSIGNMENT_DB_HOST=academic-db
ASSIGNMENT_DB_PORT=5432
ASSIGNMENT_DB_NAME=academic_db
ASSIGNMENT_DB_USER=academic_user
ASSIGNMENT_DB_PASSWORD=change_me_academic

# ─── Gateway ─────────────────────────────────────────────────
GATEWAY_PORT=8080

# ─── Ambiente ─────────────────────────────────────────────────
NODE_ENV=development
